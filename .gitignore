# =============================================================================
# bwenv .gitignore — Go project
# =============================================================================

# -- Build artifacts --
dist/
releases/
*.exe
*.exe~
*.dll
*.so
*.dylib

# -- Test artifacts --
*.test
*.out
coverage.txt
coverage.html

# -- Go workspace --
go.work
go.work.sum

# -- Environment and secrets --
.env
.envrc
.env.local
.env.*.local

# -- OS generated files --

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# -- IDE and editor files --
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp
*~
.project
.settings/
.classpath

# -- Logs --
*.log

# -- Archives (don't commit release artifacts) --
*.tar.gz
*.zip

# -- Temporary and cache directories --
.cache/
tmp/
